{
  "name": "proven-me",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:user": "turbo run dev --filter=@provenme/user",
    "dev:admin": "turbo run dev --filter=@provenme/admin",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^1.13.4"
  }
}
